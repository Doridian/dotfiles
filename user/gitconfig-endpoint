# This is Git's per-user configuration file.
[user]
	name = Doridian
	email = git@doridian.net
	signingkey = /home/doridian/.ssh/id_ecdsa.pub
[init]
	defaultBranch = main
[sendemail]
	suppresscc = self
[pull]
	rebase = true
[push]
	autoSetupRemote = yes
[gpg]
	format = ssh
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
